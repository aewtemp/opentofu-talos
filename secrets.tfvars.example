# Copy this file to secrets.tfvars and fill in real credentials.
# Add secrets.tfvars to .gitignore — never commit credentials.
#
# Usage:
#   tofu plan  -var-file=secrets.tfvars
#   tofu apply -var-file=secrets.tfvars
#
# Authentication: api_token is the primary (and recommended) method.
# Format: "<user>@<realm>!<token-id>=<uuid>"

proxmox_cluster_credentials = {
  cluster_a = { # AV-PVE / va-pve02
    api_token = "terraform@pam!deploy=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  }
  cluster_b = { # MP-PVE
    api_token = "terraform@pam!deploy=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  }
  cluster_c = { # depve10
    api_token = "terraform@pam!deploy=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  }
  cluster_d = { # depve20
    api_token = "terraform@pam!deploy=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
  }
}

# ArgoCD repository tokens — keys must match argocd_repo_secrets in argocd.auto.tfvars.
argocd_repo_tokens = {
  deployments = "gldt-xxxxxxxxxxxxxxxxxxxx"
  # second-repo = "ghp_xxxxxxxxxxxxxxxxxxxx"
}
